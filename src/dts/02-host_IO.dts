/*
 * Combined eQEP0 & eQEP1 overlay for BeagleBone Black (kernel 6.12+)
 * Targets Debian 12 with 3-cell pinmux format.
 */

/dts-v1/;
/plugin/;

/ {
    compatible = "ti,beaglebone", "ti,beaglebone-black";

    /* identification */
    part-number = "bone_eqep_combined";
    version = "00A0";

    fragment@0 {
        target = <&am33xx_pinmux>;
        __overlay__ {
            pinctrl_eqep0: pinctrl_eqep0_pins {
                pinctrl-single,pins = <
                    0x1A0 0x30 0x01  /* P9_42 = EQEP0A_in, MODE1 */
                    0x1A4 0x30 0x01  /* P9_27 = EQEP0B_in, MODE1 */
                >;
            };

            pinctrl_eqep1: pinctrl_eqep1_pins {
                pinctrl-single,pins = <
                    0x0D4 0x30 0x02  /* P8_33 = EQEP1B_in, MODE2 */
                    0x0D0 0x30 0x02  /* P8_35 = EQEP1A_in, MODE2 */
                >;
            };
        };
    };

    /* Enable EPWMSS units */
    fragment@1 {
        target = <&epwmss0>;
        __overlay__ {
            status = "okay";
        };
    };

    fragment@2 {
        target = <&epwmss1>;
        __overlay__ {
            status = "okay";
        };
    };

    /* Enable eQEP0 hardware */
    fragment@3 {
        target = <&eqep0>;
        __overlay__ {
            compatible = "ti,am3352-eqep";
            pinctrl-names = "default";
            pinctrl-0 = <&pinctrl_eqep0>;
            count_mode = <0>;
            swap_inputs = <0>;
            invert_qa = <1>;
            invert_qb = <1>;
            status = "okay";
        };
    };

    /* Enable eQEP1 hardware */
    fragment@4 {
        target = <&eqep1>;
        __overlay__ {
            compatible = "ti,am3352-eqep";
            pinctrl-names = "default";
            pinctrl-0 = <&pinctrl_eqep1>;
            count_mode = <0>;
            swap_inputs = <0>;
            invert_qa = <1>;
            invert_qb = <1>;
            status = "okay";
        };
    };
};