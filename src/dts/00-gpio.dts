/* pickup-winder-00-gpio.dts
 * Centralise toutes les déclarations pinmux GPIO du projet PickupWinder.
 * Remplace 00-pru-steppers-endstops.dts et le fragment &gpio1 de 02-host_IO.dts.
 *
 * Targets BeagleBone Black - Kernel 6.12+ (Debian 12)
 * 3-cell format: <offset config_flags mux_mode>
 *
 * Bank mapping:
 *   GPIO1 bank : P8_15 (ENDSTOP_1, PRU1 R31[15])
 *                P8_16 (ENDSTOP_2, PRU1 R31[14])
 *                P9_23 (footswitch input, GPIO1[17])
 *
 *   GPIO3 bank : P9_25 (EN_A,   PRU0 R30[7])
 *                P9_27 (DIR_A,  PRU0 R30[5])
 *                P9_29 (STEP_A, PRU0 R30[1])
 *                P9_28 (EN_B,   PRU0 R30[3])
 *                P9_31 (DIR_B,  PRU0 R30[0])
 *                P9_30 (STEP_B, PRU0 R30[2])
 *
 * Note: bone-pinmux-helper absent sur kernel 6.12 → pinmux attaché via &gpioN.
 * Chaque groupe est attaché au contrôleur GPIO propriétaire des pads.
 */

/dts-v1/;
/plugin/;

&am33xx_pinmux {

    /* ── GPIO1 : entrées endstop PRU1 (P8_15 / P8_16) ─────────────────
     * MODE6 = PRU1 R31 direct input, pull désactivé (circuit externe)    */
    pru_endstop_pins: pru-endstop-pins {
        pinctrl-single,pins = <
            0x03C 0x28 0x06  /* P8_15 ENDSTOP_1 (PRU1 R31[15]) rx-en, pull-disabled */
            0x038 0x28 0x06  /* P8_16 ENDSTOP_2 (PRU1 R31[14]) rx-en, pull-disabled */
        >;
    };

    /* ── GPIO1 : entrée host footswitch (P9_23, GPIO1[17], offset 0x044) ─
     * MODE7 = GPIO, pull-up interne activé                                */
    host_gpio_input_pins: host-gpio-input-pins {
        pinctrl-single,pins = <
            0x044 0x30 0x07  /* P9_23 footswitch : rx-en, pull-up, GPIO mode */
        >;
    };

    /* ── GPIO3 : sorties stepper PRU0 ──────────────────────────────────
     * MODE5 = PRU0 R30 direct OUTPUT  (MODE6 = R31 INPUT — ne pas confondre)
     * AM335x MCASP0 pins: MODE5 → pr1_pru0_pru_r30_N (output)
     *                     MODE6 → pr1_pru0_pru_r31_N (input)  ← MAUVAIS pour sorties
     * EN_A/EN_B : pull-up (active-low, état safe = driver désactivé si PRU OFF)
     * STEP/DIR   : pull désactivé (piloté directement par PRU0)           */
    pru_step_pins: pru-step-pins {
        pinctrl-single,pins = <
            0x1AC 0x10 0x05  /* P9_25 EN_A   (PRU0 R30[7]) pull-up, active-low, MODE5=R30 out */
            0x1A4 0x08 0x05  /* P9_27 DIR_A  (PRU0 R30[5]) no pull,             MODE5=R30 out */
            0x194 0x08 0x05  /* P9_29 STEP_A (PRU0 R30[1]) no pull,             MODE5=R30 out */
            0x19C 0x10 0x05  /* P9_28 EN_B   (PRU0 R30[3]) pull-up, active-low, MODE5=R30 out */
            0x190 0x08 0x05  /* P9_31 DIR_B  (PRU0 R30[0]) no pull,             MODE5=R30 out */
            0x198 0x08 0x05  /* P9_30 STEP_B (PRU0 R30[2]) no pull,             MODE5=R30 out */
        >;
    };
};

/* ── Attache GPIO1 : endstops (PRU1) + footswitch (host) ───────────────
 * P8_15, P8_16 et P9_23 appartiennent tous au bank GPIO1.
 * Fusionner dans un seul fragment évite un écrasement de pinctrl-0.      */
&gpio1 {
    pinctrl-names = "default";
    pinctrl-0 = <&pru_endstop_pins &host_gpio_input_pins>;
};

/* ── Attache GPIO3 : sorties stepper PRU0 ──────────────────────────────  */
&gpio3 {
    pinctrl-names = "default";
    pinctrl-0 = <&pru_step_pins>;
};
